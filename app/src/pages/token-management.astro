---
import Layout from '@/layouts/Layout.astro';
import TokenActions from '@/components/TokenActions';
import TokenSearch from '@/components/TokenSearch';
import IssuedTokensPanel from '@/components/IssuedTokensPanel';
import { INDEXER_START_CMD } from '@/lib/indexer';

const ipfsEnabled = !!process.env.PINATA_JWT;
const network = (process.env.NETWORK ?? 'mainnet').toLowerCase();
---

<Layout title="Token Management" activeNav="token-management">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-100">Token Management</h1>
    <TokenActions client:load ipfsEnabled={ipfsEnabled} />
  </div>

  <div id="indexer-warning" style="display:none"
       class="rounded-lg border border-amber-700 bg-amber-900/20 p-4 mb-6 text-amber-300 text-sm">
    <strong class="block mb-1">Indexer not running</strong>
    Some features (browsing all on-chain tokens, token search) require the indexer.
    Start it with:
    <code class="block mt-2 rounded bg-gray-900 px-3 py-1.5 text-xs text-gray-300 font-mono">{INDEXER_START_CMD}</code>
  </div>

  <div id="indexer-syncing" style="display:none"
       class="rounded-lg border border-yellow-700 bg-yellow-900/20 p-4 mb-6 text-yellow-300 text-sm">
    <strong class="block mb-1">Indexer still syncing</strong>
    Some features may not work as expected until the indexer catches up with the chain.
  </div>

  <!-- ── My Issued Tokens ──────────────────────────────────────────────────── -->
  <section class="mb-8">
    <h2 class="text-base font-semibold text-gray-200 mb-3">My Issued Tokens</h2>
    <IssuedTokensPanel client:load network={network} />
  </section>

  <!-- ── Search on-chain tokens ────────────────────────────────────────────── -->
  <section class="mb-8">
    <h2 class="text-base font-semibold text-gray-200 mb-3">Search on-chain tokens</h2>
    <div class="rounded-xl border border-amber-800/50 bg-amber-950/20 px-4 py-3 mb-3 flex items-start gap-2.5 text-sm text-amber-300">
      <svg class="shrink-0 mt-0.5" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      <span>Only add tokens you are certain are legitimate. Anyone can create a token with any name or ticker. Always verify the <strong class="font-semibold">token ID</strong> against a trusted source before interacting with it.</span>
    </div>
    <div class="rounded-xl bg-gray-900 border border-gray-800 p-6">
      <TokenSearch client:load network={network} />
    </div>
  </section>
</Layout>

<script>
fetch('/api/indexer-status')
  .then(r => r.json())
  .then((data: { up: boolean; synced: boolean }) => {
    if (!data.up) {
      const el = document.getElementById('indexer-warning');
      if (el) el.style.display = '';
    } else if (!data.synced) {
      const el = document.getElementById('indexer-syncing');
      if (el) el.style.display = '';
    }
  })
  .catch(() => {});
</script>
