---
import Layout from '@/layouts/Layout.astro';
import { openWallet, createWallet } from '@/lib/wallet-rpc';

let successAction: 'open' | 'create' | null = null;
let successMnemonic: string | undefined;
let errorMessage: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action') as string;

  if (action === 'open') {
    const walletPath = (form.get('wallet_path') as string | null)?.trim() ?? '';
    const password   = (form.get('password')    as string | null)?.trim() || undefined;

    if (!walletPath) {
      errorMessage = 'Wallet path is required.';
    } else {
      try {
        await openWallet(walletPath, password);
        successAction = 'open';
      } catch (err) {
        errorMessage = (err as Error).message;
      }
    }
  } else if (action === 'create') {
    const walletPath = (form.get('wallet_path') as string | null)?.trim() ?? '';
    const storeSeed  = form.get('store_seed') === 'yes';
    const mnemonic   = (form.get('mnemonic') as string | null)?.trim() || undefined;

    if (!walletPath) {
      errorMessage = 'Wallet path is required.';
    } else {
      try {
        const res = await createWallet(walletPath, storeSeed, mnemonic);
        successAction = 'create';
        if (res.mnemonic.type === 'NewlyGenerated') {
          successMnemonic = res.mnemonic.content.mnemonic;
        }
      } catch (err) {
        errorMessage = (err as Error).message;
      }
    }
  }
}
---

<Layout title="Wallet Setup" activeNav="setup">
  <h1 class="text-2xl font-bold text-gray-100 mb-2">Wallet Setup</h1>
  <p class="text-sm text-gray-400 mb-8 max-w-xl">
    The <code class="bg-gray-800 px-1 rounded">wallet-rpc-daemon</code> manages one wallet file at a time.
    Paths are inside the container: wallet files live in <code class="bg-gray-800 px-1 rounded">/home/mintlayer/</code>,
    which maps to <code class="bg-gray-800 px-1 rounded">./mintlayer-data/</code> on your host.
  </p>

  <!-- Result banner -->
  {errorMessage && (
    <div class="rounded-lg border border-red-700 bg-red-900/30 p-4 mb-6 text-red-300 text-sm">
      <strong class="font-semibold">Error:</strong> {errorMessage}
    </div>
  )}

  {successAction === 'open' && (
    <div class="rounded-lg border border-mint-700 bg-mint-900/30 p-4 mb-6 text-mint-300 text-sm">
      <strong class="font-semibold">Wallet opened successfully.</strong>
      {' '}<a href="/" class="underline hover:text-mint-100">Go to dashboard →</a>
    </div>
  )}

  {successAction === 'create' && (
    <div class="rounded-lg border border-mint-700 bg-mint-900/30 p-5 mb-6">
      <p class="text-mint-300 font-semibold text-sm mb-2">Wallet created successfully!</p>
      {successMnemonic && (
        <>
          <p class="text-xs text-yellow-400 mb-1 font-semibold">
            Write down your seed phrase and store it safely. It will not be shown again.
          </p>
          <pre class="text-xs font-mono text-mint-200 bg-gray-950 rounded-lg p-3 break-words whitespace-pre-wrap">{successMnemonic}</pre>
        </>
      )}
      <a href="/" class="inline-block mt-3 text-sm underline text-mint-400 hover:text-mint-300">
        Go to dashboard →
      </a>
    </div>
  )}

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl">
    <!-- Open existing wallet -->
    <div class="rounded-xl bg-gray-900 border border-gray-800 p-6">
      <h2 class="text-base font-semibold text-gray-200 mb-4">Open existing wallet</h2>
      <form method="POST" class="space-y-4">
        <input type="hidden" name="action" value="open" />

        <div>
          <label for="open-path" class="block text-xs text-gray-400 mb-1">Wallet file path</label>
          <input
            id="open-path"
            name="wallet_path"
            type="text"
            required
            placeholder="/home/mintlayer/my_wallet"
            class="w-full rounded-lg bg-gray-800 border border-gray-700 text-gray-100 placeholder-gray-600
                   px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-mint-600"
          />
        </div>

        <div>
          <label for="open-password" class="block text-xs text-gray-400 mb-1">
            Password <span class="text-gray-600">(leave blank if unencrypted)</span>
          </label>
          <input
            id="open-password"
            name="password"
            type="password"
            placeholder="••••••••"
            class="w-full rounded-lg bg-gray-800 border border-gray-700 text-gray-100 placeholder-gray-600
                   px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-mint-600"
          />
        </div>

        <button
          type="submit"
          class="w-full rounded-lg bg-gray-700 hover:bg-gray-600 px-4 py-2 text-sm font-medium text-gray-100 transition-colors"
        >
          Open Wallet
        </button>
      </form>
    </div>

    <!-- Create new wallet -->
    <div class="rounded-xl bg-gray-900 border border-gray-800 p-6">
      <h2 class="text-base font-semibold text-gray-200 mb-4">Create new wallet</h2>
      <form method="POST" class="space-y-4">
        <input type="hidden" name="action" value="create" />

        <div>
          <label for="create-path" class="block text-xs text-gray-400 mb-1">Wallet file path</label>
          <input
            id="create-path"
            name="wallet_path"
            type="text"
            required
            placeholder="/home/mintlayer/my_wallet"
            class="w-full rounded-lg bg-gray-800 border border-gray-700 text-gray-100 placeholder-gray-600
                   px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-mint-600"
          />
        </div>

        <div>
          <label for="create-mnemonic" class="block text-xs text-gray-400 mb-1">
            Mnemonic <span class="text-gray-600">(leave blank to generate a new one)</span>
          </label>
          <textarea
            id="create-mnemonic"
            name="mnemonic"
            rows="2"
            placeholder="word1 word2 word3 … word12"
            class="w-full rounded-lg bg-gray-800 border border-gray-700 text-gray-100 placeholder-gray-600
                   px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-mint-600 resize-none"
          />
        </div>

        <div class="flex items-center gap-2">
          <input
            id="store-seed"
            name="store_seed"
            type="checkbox"
            value="yes"
            checked
            class="accent-mint-500 w-4 h-4"
          />
          <label for="store-seed" class="text-xs text-gray-400">
            Store seed phrase in wallet file
          </label>
        </div>

        <button
          type="submit"
          class="w-full rounded-lg bg-mint-700 hover:bg-mint-600 px-4 py-2 text-sm font-semibold text-white transition-colors"
        >
          Create Wallet
        </button>
      </form>
    </div>
  </div>
</Layout>
