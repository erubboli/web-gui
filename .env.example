# ─────────────────────────────────────────────────────
# Mintlayer Web GUI — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────

# Docker user/group IDs (match your host user to avoid permission issues)
ML_USER_ID=1000
ML_GROUP_ID=1000

# ── Node RPC ─────────────────────────────────────────
# Credentials for the node-daemon RPC server.
NODE_RPC_USERNAME=node_user
NODE_RPC_PASSWORD=node_password_change_me

# ── Wallet RPC ────────────────────────────────────────
# Credentials for the wallet-rpc-daemon.
# IMPORTANT: Change these before running in any exposed environment.
WALLET_RPC_USERNAME=wallet_user
WALLET_RPC_PASSWORD=wallet_password_change_me

# Full command for the wallet-rpc-daemon container.
# init.sh writes this automatically. Edit it here to change the wallet file
# or network, then run: docker compose restart wallet-rpc-daemon
#
# No wallet file (daemon starts, create one via /setup):
WALLET_RPC_CMD=wallet-rpc-daemon mainnet
#
# With a wallet file:
# WALLET_RPC_CMD=wallet-rpc-daemon mainnet --wallet-file /home/mintlayer/my_wallet

# ── Web GUI ───────────────────────────────────────────
# Port the Astro web interface listens on (host port).
WEB_GUI_PORT=4321

# ── Web UI Authentication ─────────────────────────────
# Generated automatically by init.sh — do NOT edit manually.
# To change the password or reset 2FA, re-run ./init.sh.
#
# UI_PASSWORD_HASH: PBKDF2-SHA512 hash of the login password.
# UI_TOTP_SECRET:   Base32 TOTP secret (RFC 6238, Google Authenticator compatible).
# SESSION_SECRET:   32+ byte hex key used to sign session cookies.
UI_PASSWORD_HASH=pbkdf2:sha512:100000:<salt_hex>:<key_hex>
UI_TOTP_SECRET=BASE32TOTPSECRETHERE
SESSION_SECRET=<64-hex-chars-random>

# ── Indexer (optional, profile: indexer) ─────────────
# Only needed when running: docker compose --profile indexer up
POSTGRES_USER=mintlayer
POSTGRES_PASSWORD=postgres_password_change_me
POSTGRES_DB=mintlayer

# Port exposed by the api-web-server (blockchain REST API).
API_WEB_SERVER_PORT=3000

# ── IPFS (optional) ──────────────────────────────────
# Pinata JWT for IPFS uploads (token metadata images, NFT media).
# Get one at https://app.pinata.cloud — the free tier is sufficient.
# Leave empty to disable IPFS upload (URLs can still be entered manually).
PINATA_JWT=

# ── Misc ─────────────────────────────────────────────
# Log level for Rust-based services (error, warn, info, debug, trace)
RUST_LOG=info
